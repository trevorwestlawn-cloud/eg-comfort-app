# Housecall Pro API integration -- copy to .env (gitignored) for local
# development, or set these in Vercel project settings for production.

# Required to enable HCP integration. Without these, the app falls back
# to mock data on the property lookup and disables the order push.
HCP_API_KEY=
HCP_API_BASE=https://api.housecallpro.com

# Optional: HCP custom field names that store property attributes.
# Defaults shown -- override only if your HCP fields use different keys.
HCP_FIELD_SQFT=square_feet
HCP_FIELD_YEAR_BUILT=year_built
HCP_FIELD_SYSTEMS=hvac_system_count
HCP_FIELD_HAS_POOL=has_pool
